# ── CloudChat Server Configuration ──────────────────────────
# Copy this file to .env and fill in the values.

# Google AI API key (required) — get one at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Model to use (default: gemma-4-e2b-it)
# See: https://ai.google.dev/gemma/docs/core/model_card_4
GEMMA_MODEL=gemma-4-e2b-it

# Server port (default: 3000)
PORT=3000
