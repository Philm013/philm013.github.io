# Gemini CLI Global Configuration Template
# To use this globally, copy this file to: ~/.gemini/.env

# --- GitHub Authentication ---
# Used for git operations, GitHub API access, and repository management.
# Create a token at https://github.com/settings/tokens
GITHUB_TOKEN="your_github_personal_access_token_here"

# --- Google Gemini API ---
# If you are using a direct API key instead of the /auth command.
# GEMINI_API_KEY="your_google_ai_studio_api_key_here"

# --- Other Common Integrations ---
# PEXELS_API_KEY="your_pexels_key_here"
# UNSPLASH_ACCESS_KEY="your_unsplash_key_here"
# SMARTSHEET_API_TOKEN="your_smartsheet_access_token_here"
# SUPERSMARTSHEET_PORT="3210"

# --- Security Note ---
# The Gemini CLI automatically redacts sensitive variables containing "TOKEN", "SECRET", or "KEY".
# To allow specific variables to be visible to tools, add them to ~/.gemini/settings.json:
# "security": { "environmentVariableRedaction": { "allowed": ["GITHUB_TOKEN"] } }
